generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  PENDING
  COMPLETED
  MISSED
}

enum CheckInStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
}

enum VerificationVerdict {
  APPROVE
  FLAG
}

enum GroupVisibility {
  PRIVATE
  PUBLIC
}

enum GroupFocusType {
  GENERAL
  DSA
  DEVELOPMENT
  EXAM_PREP
  MACHINE_LEARNING
  CUSTOM
}

enum TaskPostingMode {
  ADMINS_ONLY
  ALL_MEMBERS
}

enum PenaltyMode {
  BURN
  POOL
}

enum UserRole {
  member
  admin
}

enum GroupRole {
  member
  admin
}

enum TaskCategory {
  DSA
  DEVELOPMENT
  REVISION
  INTERVIEW_PREP
  READING
  CUSTOM
}

enum TaskScope {
  PERSONAL
  GROUP
}

enum NotificationKind {
  PRE_DEADLINE_NUDGE
  FLAGGED_SUBMISSION
}

enum GroupMessageReactionKind {
  FIRE
  CLAP
  TARGET
  ROCKET
}

model User {
  id                      String                  @id
  name                    String
  email                   String
  emailVerified           Boolean                 @default(false)
  image                   String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  role                    UserRole                @default(member)
  isBlocked               Boolean?
  penaltyCount            Int                     @default(0)
  sessions                Session[]
  accounts                Account[]
  groups                  UserGroup[]
  createdGroups           Group[]                 @relation("GroupCreator")
  tasks                   Task[]
  checkIns                CheckIn[]
  messages                GroupMessage[]
  submissionVerifications SubmissionVerification[]
  penaltyEvents           PenaltyEvent[]
  startFiles              StartFile[]
  endFiles                EndFile[]
  notificationLogs        NotificationLog[]
  taskTemplates           TaskTemplate[]          @relation("UserTaskTemplates")
  createdTaskTemplates    TaskTemplate[]          @relation("CreatedTaskTemplates")
  messageReactions        GroupMessageReaction[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Group {
  id                String                  @id @default(cuid())
  name              String
  description       String?
  link              String?
  visibility        GroupVisibility         @default(PRIVATE)
  focusType         GroupFocusType          @default(GENERAL)
  taskPostingMode   TaskPostingMode         @default(ALL_MEMBERS)
  penaltyMode       PenaltyMode             @default(BURN)
  inviteCode        String                  @unique
  inviteExpiresAt   DateTime
  maxMembers        Int                     @default(8)
  dailyPenalty      Int                     @default(10)
  createdById       String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  createdBy         User                    @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  users             UserGroup[]
  tasks             Task[]
  checkIns          CheckIn[]
  messages          GroupMessage[]
  penaltyEvents     PenaltyEvent[]
  startFiles        StartFile[]
  endFiles          EndFile[]
  notificationLogs  NotificationLog[]
  taskTemplates     TaskTemplate[]

  @@index([createdById])
  @@index([visibility, createdAt])
  @@map("group")
}

model UserGroup {
  userId          String
  groupId         String
  joinedAt        DateTime @default(now())
  role            GroupRole @default(member)
  points          Int      @default(0)
  streak          Int      @default(0)
  completions     Int      @default(0)
  misses          Int      @default(0)
  reputationScore Int      @default(60)
  inactivityStrikes Int    @default(0)
  lastCheckInAt  DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@map("user_group")
}

model Task {
  id          String      @id @default(cuid())
  title       String
  details     String?
  category    TaskCategory @default(CUSTOM)
  targetMinutes Int?
  status      TaskStatus  @default(PENDING)
  day         DateTime
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  completedAt DateTime?
  userId      String
  groupId     String
  checkInId   String?
  templateId  String?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn     CheckIn?    @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  template    TaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([userId, day])
  @@index([groupId, day])
  @@index([templateId, day], map: "task_template_day_idx")
  @@map("task")
}

model CheckIn {
  id            String                  @id @default(cuid())
  day           DateTime
  reflection    String?
  proofText     String?
  proofLink     String?
  aiSummary     String?
  aiConfidence  Int?
  status        CheckInStatus           @default(PENDING)
  pointsAwarded Int                     @default(0)
  penaltyApplied Int                    @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  verifiedAt    DateTime?
  userId        String
  groupId       String
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         Group                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks         Task[]
  verifications SubmissionVerification[]
  penalties     PenaltyEvent[]
  startFiles    StartFile[]
  endFiles      EndFile[]
  notificationLogs NotificationLog[]

  @@index([groupId, day])
  @@index([userId, day])
  @@map("check_in")
}

model SubmissionVerification {
  id         String              @id @default(cuid())
  verdict    VerificationVerdict
  note       String?
  createdAt  DateTime            @default(now())
  checkInId  String
  reviewerId String
  checkIn    CheckIn             @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  reviewer   User                @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([checkInId])
  @@index([reviewerId])
  @@unique([checkInId, reviewerId])
  @@map("submission_verification")
}

model PenaltyEvent {
  id        String    @id @default(cuid())
  points    Int
  reason    String
  createdAt DateTime  @default(now())
  userId    String
  groupId   String
  checkInId String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn   CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt])
  @@index([userId, createdAt])
  @@map("penalty_event")
}

model GroupMessage {
  id              String                 @id @default(cuid())
  content         String?
  imageUrl        String?
  imageName       String?
  imageStorageKey String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  userId          String
  groupId         String
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group           Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  reactions       GroupMessageReaction[]

  @@index([groupId, createdAt])
  @@index([userId, createdAt])
  @@map("group_message")
}

model TaskTemplate {
  id            String      @id @default(cuid())
  title         String
  details       String?
  category      TaskCategory @default(CUSTOM)
  targetMinutes Int?
  scope         TaskScope   @default(PERSONAL)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String?
  groupId       String
  createdById   String
  user          User?       @relation("UserTaskTemplates", fields: [userId], references: [id], onDelete: Cascade)
  group         Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy     User        @relation("CreatedTaskTemplates", fields: [createdById], references: [id], onDelete: Cascade)
  tasks         Task[]

  @@index([groupId, scope, isActive])
  @@index([userId, isActive])
  @@map("task_template")
}

model StartFile {
  id         String    @id @default(cuid())
  name       String
  url        String
  storageKey String?
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  groupId    String
  checkInId  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn    CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@map("start_file")
}

model EndFile {
  id         String    @id @default(cuid())
  name       String
  url        String
  storageKey String?
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  groupId    String
  checkInId  String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  checkIn    CheckIn?  @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@map("end_file")
}

model NotificationLog {
  id        String           @id @default(cuid())
  kind      NotificationKind
  dedupeKey String           @unique
  sentAt    DateTime         @default(now())
  taskDay   DateTime?
  userId    String
  groupId   String?
  checkInId String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group?           @relation(fields: [groupId], references: [id], onDelete: SetNull)
  checkIn   CheckIn?         @relation(fields: [checkInId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
  @@index([groupId, sentAt])
  @@map("notification_log")
}

model GroupMessageReaction {
  id        String                   @id @default(cuid())
  kind      GroupMessageReactionKind
  createdAt DateTime                 @default(now())
  userId    String
  messageId String
  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   GroupMessage             @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, kind])
  @@index([messageId])
  @@index([userId])
  @@map("group_message_reaction")
}
